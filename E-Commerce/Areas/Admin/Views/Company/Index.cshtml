@model List<Company>

<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">
                Company List
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Company" asp-action="Details" asp-route-actionType="create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i>
                Create New Company
            </a>
        </div>
    </div>
</div>
@if(Model.Count == 0)
{
    <div class="alert alert-info text-center">
        No companies available. Please add a new company.
    </div>
}
else
{
    <table id="company-table" class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Phone Number</th>
                <th>Street Address</th>
                <th>State</th>
                <th>Postal Code</th>
                <th>Actions</th>
            </tr>
        </thead>
    </table>
}

@section Scripts {
    <partial name="_ToastrConfig" />
}