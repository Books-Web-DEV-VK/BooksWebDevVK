@using Microsoft.AspNetCore.Mvc;
@model Company
@{
    bool hasModelLevelErrors = ViewData.ModelState[string.Empty]?.Errors.Count > 0;
    string actionType = ViewBag.ActionType?.ToString().ToLower() ?? "view";
    string cancelAction = actionType == "view" ? "Back to Category List" : "Cancel";
    var isReadOnly = (actionType == "view").ToString().ToLower();

    string heading = actionType switch
    {
        "create" => "Enter new company details",
        "edit" => "Edit Company Details",
        _ => "Company Details"
    };
}

@actionType
@cancelAction
@isReadOnly
@Model?.Id

<form asp-area="Admin" asp-controller="Company" asp-action='ManageCompanies' asp-route-actionType="@actionType" method="post" enctype="multipart/form-data">
    <div class="p-3 mt-4 border-black">
        <div class="row pb-2">
            <h2 class="text-primary"> @heading.ToUpper() </h2>
            <hr />
        </div>
        @if (hasModelLevelErrors)
        {
            <div class="alert alert-danger" role="alert">
                <div asp-validation-summary="ModelOnly"></div>
                <!-- asp-validation-summary=All , both the field level errors and the model leve;errors -->
                <!-- asp-validation-summary=ModelOnly , Only model level errors -->
                <!-- asp-validation-summary=None , Nothing will be visible -->
            </div>
        }
        <input asp-for="Id" type="hidden" />
        <div class="mb-3 row">
            <label asp-for="Name" class="p-0"></label>
            <input type="text" asp-for="Name" rows="10" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3 row">
            <label asp-for="PhoneNumber" class="p-0"></label>
            <input type="number" maxLength=12 asp-for="PhoneNumber" class="form-control" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>
        <div class="mb-3 row">
            <label asp-for="StreetAddress" class="p-0"></label>
            <textarea asp-for="StreetAddress" class="form-control"></textarea>
            <span asp-validation-for="StreetAddress" class="text-danger"></span>
        </div>
        <div class="mb-3 row">
            <label asp-for="City" class="p-0"></label>
            <input type="text" asp-for="City" class="form-control" />
            <span asp-validation-for="City" class="text-danger"></span>
        </div>
        <div class="mb-3 row">
            <label asp-for="State" class="p-0"></label>
            <input type="text" asp-for="State" class="form-control" />
            <span asp-validation-for="State" class="text-danger"></span>
        </div>
        <div class="mb-3 row">
            <label asp-for="PostalCode" class="p-0"></label>
            <input type="number" asp-for="PostalCode" class="form-control" />
            <span asp-validation-for="PostalCode" class="text-danger"></span>
        </div>
        <div class="row">
            @if (actionType == "view")
            {
                <div class="col-6">
                    <a asp-area="Admin" asp-controller="Company" asp-action="Index" class="btn btn-secondary form-control">
                        @cancelAction.ToUpper()
                    </a>
                </div>
            }
            else
            {
                <div class="col-6">
                    <button type="submit" class="btn btn-primary form-control">@actionType.ToUpper() COMPANY</button>
                </div>
                <div class="col-6">
                    <a asp-area="Admin" asp-controller="Company" asp-action="Index" class="btn btn-secondary form-control">
                        @cancelAction.ToUpper()
                    </a>
                </div>
            }
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/toastr.js/toastr.min.js"></script>
    <script>
        if ('@isReadOnly'=="true") {
            document.querySelectorAll('input, select, textarea').forEach(element => {
                element.setAttribute('readonly', 'readonly');
            });
        }
    </script>
}