@model List<Product>

<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">
                Product List
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Product" asp-action="Details" asp-route-actionType="create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i>
                Create New Product
            </a>
        </div> 
    </div>
</div>
<table id="product-table" class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>ISBN</th>
            <th>Author</th>
            <th>List Price</th>
            <th>Category</th>
            <th>Actions</th> 
        </tr>
    </thead>
