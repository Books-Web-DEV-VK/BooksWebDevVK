@model List<Product>

<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">
                Product List
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Product" asp-action="CreateProduct" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i>
                Create New Product
            </a>
        </div> 
    </div>
</div>
<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>ISBN</th>
            <th>Author</th>
            <th>List Price</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model.OrderBy(product=>product.Title))
        {
            <tr>
                <td>@product.Title</td>
                <td>@product.ISBN</td>
                <td>@product.Author</td>
                <td>@product.ListPrice</td>
                <td>
                    <a asp-controller="Product" asp-action="ViewProduct" asp-route-id="@product.Id" asp-route-actionType="edit" class="btn btn-info mx-2 rounded-2">
                        <i class="bi bi-pencil-square"></i>
                        Edit Product
                    </a>
                    <a asp-controller="Product" asp-action="ViewProduct" asp-route-id="@product.Id" asp-route-actionType="delete" class="btn btn-danger mx-2 rounded-2">
                        <i class="bi bi-trash-fill"></i>
                        Delete Product
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <partial name="_ToastrConfig" />
}

