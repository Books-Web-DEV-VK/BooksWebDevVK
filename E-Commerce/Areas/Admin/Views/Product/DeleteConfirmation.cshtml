@model ProductVM

<form asp-area="Admin" asp-action="DeleteProduct" method="post">
    <div class="p-3 mt-4 border-black">
        <div class="row pb-2">
            <h2 class="text-primary"> Are you sure want to delete following Product ? </h2>
            <hr />
        </div>
        <input type="hidden" asp-for="Product.Id" />
        <div class="mb-3 row">
            <label asp-for="Product.Title" class="p-0 col-6"></label>
            <input type="text" asp-for="Product.Title" class="col-6 form-control" readonly />
        </div>
        <div class="mb-3 row">
            <label asp-for="Product.Description" class="p-0 col-6"></label>
            <input type="text" asp-for="Product.Description" class="col-6 form-control" readonly />
        </div>
        <div class="mb-3 row">
            <label asp-for="Product.ISBN" class="p-0 col-6"></label>
            <input type="text" asp-for="Product.ISBN" class="col-6 form-control" readonly />
        </div>
        <div class="mb-3 row">
            <label asp-for="Product.Author" class="p-0 col-6"></label>
            <input type="text" asp-for="Product.Author" class="col-6 form-control" readonly />
        </div>
        <div class="mb-3 row">
            <label asp-for="Product.ListPrice" class="p-0 col-6"></label>
            <input type="number" asp-for="Product.ListPrice" class="col-6 form-control" readonly />
        </div>
        <div class="mb-3 row">
            <label asp-for="Product.Price" class="p-0 col-6"></label>
            <input type="number" asp-for="Product.Price" class="col-6 form-control" readonly />
        </div>
        <div class="mb-3 row">
            <label asp-for="Product.Price50" class="p-0 col-6"></label>
            <input type="number" asp-for="Product.Price50" class="col-6 form-control" readonly />
        </div>
        <div class="mb-3 row">
            <label asp-for="Product.Price100" class="p-0 col-6"></label>
            <input type="number" asp-for="Product.Price100" class="col-6 form-control" readonly />
        </div>
        <div class="mb-3 row">
            <label asp-for="Product.ImageUrl" class="p-0"></label>
            <input type="number" asp-for="Product.ImageUrl" class="col-6 form-control" readonly />
        </div>
        <div class="mb-3 row">
            <label asp-for="Product.CategoryId" class="p-0"></label>
            <select asp-for="Product.CategoryId" class="col-6 form-select" readonly>
                <option disabled selected value="">-- Select Category --</option>
                @foreach (var category in Model.CategoryList)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </div>
        <div class="row">
            <div class="col-6">
                <button type="submit" class="btn btn-danger form-control">Delete</button>
            </div>
            <div class="col-6">
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary form-control">
                    Cancel
                </a>
            </div>
        </div>
    </div>
</form>
