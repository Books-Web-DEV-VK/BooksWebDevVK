@using BooksWeb.Utility
@model OrderVM
@{
    bool canWrite = User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee);
    bool isReadOnly = !canWrite;
}
<form method="post" class="m-auto" id="orderDetailsForm">
<div class="card shadow-lg m-auto">
    <div class="card-header rounded-top-3 bg-primary text-white p-3 fw-bolder fs2">
        Order Details
    </div>
    <div class="card-body rounded-bottom-3 p-5">
        <div class="row">
            <div class="col-6 p-4 border-1 border-end">
                    <div class="row mb-3">
                        <h2>PickUp Details:</h2>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="@Model.OrderHeader.Name" class="col-4 fw-bold">
                            Name:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.Name" type="text" class="form-control" readonly="@isReadOnly" />
                            <span asp-validation-for="@Model.OrderHeader.Name" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="@Model.OrderHeader.PhoneNumber" class="col-4 fw-bold">
                            Phone Number:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.PhoneNumber" type="text" class="form-control" value="@Model.OrderHeader.PhoneNumber" readonly="@isReadOnly" />
                            <span asp-validation-for="@Model.OrderHeader.PhoneNumber" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for"@Model.OrderHeader.StreetAddress" class="col-4 fw-bold">
                            Street Address:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.StreetAddress" type="text" class="form-control" value="@Model.OrderHeader.StreetAddress" readonly="@isReadOnly" />
                            <span asp-validation-for="@Model.OrderHeader.StreetAddress" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="@Model.OrderHeader.City" class="col-4 fw-bold">
                            City:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.City" type="text" class="form-control" value="@Model.OrderHeader.City" readonly="@isReadOnly" />
                            <span asp-validation-for="@Model.OrderHeader.City" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="@Model.OrderHeader.State" class="col-4 fw-bold">
                            State:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.State" type="text" class="form-control" value="@Model.OrderHeader.State" readonly="@isReadOnly" />
                            <span asp-validation-for="@Model.OrderHeader.State" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="@Model.OrderHeader.PostalCode" class="col-4 fw-bold">
                            Zip Code:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.PostalCode" type="text" class="form-control" readonly="@isReadOnly" />
                            <span asp-validation-for="@Model.OrderHeader.PostalCode" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="@Model.OrderHeader.ApplicationUser.Email" class="col-4 fw-bold">
                            Email:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.ApplicationUser.Email" type="text" class="form-control" readonly="@isReadOnly" />
                            <span asp-validation-for="@Model.OrderHeader.ApplicationUser.Email" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="@Model.OrderHeader.OrderDate" class="col-4 fw-bold">
                            Order Date:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.OrderDate" type="text" class="form-control" readonly="@isReadOnly" />
                            <span asp-validation-for="@Model.OrderHeader.OrderDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="@Model.OrderHeader.Carrier" class="col-4 fw-bold">
                            Carrier:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.Carrier" type="text" class="form-control" readonly="@isReadOnly" />
                            <span asp-validation-for="@Model.OrderHeader.Carrier" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="@Model.OrderHeader.TrackingNumber" class="col-4 fw-bold">
                            Tracking Number:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.TrackingNumber" type="text" class="form-control" readonly="@isReadOnly" />
                            <span asp-validation-for="@Model.OrderHeader.TrackingNumber" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="@Model.OrderHeader.ShippedDate" class="col-4 fw-bold">
                            Shipping Date:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.ShippedDate" type="text" class="form-control" readonly="@isReadOnly" />
                            <span asp-validation-for="@Model.OrderHeader.ShippedDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="@Model.OrderHeader.PaymentDate" class="col-4 fw-bold">
                            Payment Date:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.PaymentDate" type="text" class="form-control"  />
                            <span asp-validation-for="@Model.OrderHeader.PaymentDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="@Model.OrderHeader.PaymentStatus" class="col-4 fw-bold">
                            Payment Status:
                        </label>
                        <div class="col-8">
                            <input asp-for="@Model.OrderHeader.PaymentStatus" type="text" class="form-control" readonly="@isReadOnly" />
                            <span asp-validation-for="@Model.OrderHeader.PaymentStatus" class="text-danger"></span>
                        </div>
                    </div>
                    <input asp-for="@Model.OrderHeader.Id" type="hidden" />
                    @if(canWrite)
                    {
                        <div class="text-center">
                            <button type="submit" asp-action="UpdateOrderDetails" class="btn btn-warning rounded-3 fw-bold text-white"> Update Details </button>
                        </div>
                    } 
            </div>
            <div class="col-6 p-4 border-1 border-start">
                <div class="row mb-3">
                    <h2>Order Summary</h2>
                </div>
                <div class="row mb-3 border-primary rounded-3">
                    <h3 class="p-3">ORDER STATUS : @Model.OrderHeader.OrderStatus</h3>
                </div>
                <div class="row mb-3 border-secondary rounded-3">
                    @foreach(var orderDetail in Model.OrderDetails)
                    {
                        <div class="my-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="fw-bold">@orderDetail.Product.Title</div>
                                <div>@((orderDetail.Price * orderDetail.Count).ToString("c"))</div>
                            </div>
                            <div>
                                Price : @orderDetail.Price.ToString("c")
                            </div>
                            <div>
                                Quantity : @orderDetail.Count
                            </div>
                        </div>
                    }
                    <div class="d-flex justify-content-between align-items-center border-2 border-top">
                        <div class="fs-3 fw-bold">
                            TOTAL
                        </div>
                        <div class="fs-3 fw-bold">
                            @Model.OrderHeader.OrderTotal.ToString("c")
                        </div>
                    </div>
                    @if(Model.OrderHeader.OrderStatus == SD.StatusCancelled && Model.OrderHeader.PaymentStatus == SD.PaymentStatusRefunded)
                    {
                        <div class="d-flex justify-content-between align-items-center border-2 border-top">
                            <div class="fs-3 fw-bold text-info-emphasis">
                                Refund has been initiated. You'll receive the amount in 5-7 business days.
                            </div>
                        </div>
                    }     
                </div>
                <div class="d-flex flex-column justify-content-evenly align-items-center mb-3">
                    @if(Model.OrderHeader.PaymentStatus==SD.PaymentStatusDelayedPayment && Model.OrderHeader.OrderStatus==SD.StatusShipped && !canWrite)
                    {
                        @* Pay Button is only for Users of role : Company => Because for them 30 days Payment Waiver Options exist *@
                        <button asp-area="Customer" asp-controller="ShoppingCart" asp-action="SettleDelayedPayment" class="btn btn-success mb-3 rounded-3 w-50">
                            Complete your Payment
                        </button>
                    }
                    @if(canWrite)
                    {
                        @* Only Admin and Employees are allowed to move the order progress like from Approved-> Start Processing-> Ship Order *@
                        @if(Model.OrderHeader.OrderStatus==SD.StatusApproved)
                        {
                            <button asp-area="Admin" asp-controller="Order" asp-action="StartProcessing" class="btn btn-info mb-3 rounded-3 w-50">
                                Start Processing
                            </button>
                        }
                        @* StatusInProgress means Order is Approved, Processing Started but not yet Shipped *@
                        @if(Model.OrderHeader.OrderStatus == SD.StatusInProgress) 
                        {
                            <button asp-area="Admin" asp-controller="Order" asp-action="ShipOrder" onclick="verifyShippingDetails()" class="btn btn-info mb-3 rounded-3 w-50">
                              Ship Order
                            </button>
                        }
                        @if(Model.OrderHeader.OrderStatus == SD.StatusShipped && Model.OrderHeader.PaymentStatus == SD.PaymentStatusApproved)
                        {
                            <button asp-action="DeliverOrder" class="btn btn-danger mb-3 rounded-3 w-50">
                                Deliver Order
                            </button>
                        }
                    }
                    @* Customer/Company can cancel Order *@
                    @if (!canWrite && Model.OrderHeader.OrderStatus != SD.StatusCancelled && Model.OrderHeader.OrderStatus != SD.StatusShipped && Model.OrderHeader.OrderStatus != SD.StatusDelivered)
                    {
                        <button asp-action="CancelOrder" onclick="confirmOrderCancellation()" class="btn btn-danger mb-3 rounded-3 w-50">
                            Cancel Order
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
</form>

@section Scripts {
    <partial name="_ToastrConfig" />
    <script>
        function verifyShippingDetails() {
            const carrier = document.getElementById("OrderHeader_Carrier").value;
            const trackingNumber = document.getElementById("OrderHeader_TrackingNumber").value;
            if (!carrier || !trackingNumber) {
                Swal.fire({
                  icon: "error",
                  title: "Oops...",
                  text: "Please fill the Tracking Number and the Carrier Details!"
                });
                event.preventDefault(); 
            }
        }

        function confirmOrderCancellation() {
            event.preventDefault(); 
            Swal.fire({
                title: "Are you sure?",
                text: "Do you really want to cancel this order? This action cannot be undone.",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                cancelButtonColor: "#3085d6",
                confirmButtonText: "Yes, cancel it!",
                cancelButtonText: "No, keep it"
            }).then((result) => {
                if (result.isConfirmed) {
                    var form = document.getElementById("orderDetailsForm");
                    form.action = "/Admin/Order/CancelOrder";
                    form.submit();
                }
            });
        }
   </script>
}
