@model List<ApplicationUser>

<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">
                User List
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="User" asp-action="Details" asp-route-actionType="create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i>
                Create New User
            </a>
        </div>
    </div>
</div>
<table id="user-table" class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone Number</th>
            <th>Company</th>
            <th>Role</th>
            <th>Actions</th>
        </tr>
    </thead>
</table>

@section Scripts {
    <partial name="_ToastrConfig" />
}

