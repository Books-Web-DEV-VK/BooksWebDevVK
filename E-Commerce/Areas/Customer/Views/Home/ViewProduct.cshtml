@model ShoppingCart

<div class="container my-5">
    <form asp-action="AddToCart" method="post" class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <input type="hidden" asp-for="@Model.Product.Id" />
        <div class="row g-0 align-items-stretch">

            <!-- Product Image -->
            <div class="col-md-4 bg-body-secondary d-flex align-items-center justify-content-center">
                <img src="@Model.Product.ImageUrl"
                     class="img-fluid shadow-sm w-100 h-100"
                     alt="@Model.Product.Title"
                     onerror="this.src='/images/no-image.png'">
            </div>

            <!-- Product Details -->
            <div class="col-md-8">
                <div class="card-body p-4 p-lg-5">
                    <!-- Back To Home Page -->
                    <div class="d-flex flex-wrap gap-3">
                        <a asp-action="Index"
                           class="btn btn-outline-light rounded-2 px-4 mb-3">
                            Back to List
                        </a>
                    </div>

                    <!-- Category -->
                    <span class="badge text-dark mb-3 px-3 py-2 rounded-pill bg-warning">
                        @Model.Product?.Category?.Name
                    </span>

                    <!-- Title -->
                    <h2 class="fw-bold mb-1">@Model.Product?.Title</h2>
                    <p class="text-muted mb-4">by <span class="fw-medium">@Model.Product?.Author</span></p>

                    <!-- Description -->
                    @if (!string.IsNullOrWhiteSpace(Model.Product?.Description))
                    {
                        <p class="text-secondary mb-4">
                            @Model.Product?.Description
                        </p>
                    }

                    <hr class="my-4">

                    <!-- Meta Info -->
                    <div class="row mb-4">
                        <div class="col-sm-6 mb-3">
                            <small class="text-muted d-block">List Price</small>
                            <span class="fs-3 text-decoration-line-through text-muted">
                                ₹@Model?.Product?.ListPrice
                            </span>
                        </div>
                        <div class="col-sm-6 mb-3 text-sm-end">
                            <small class="text-muted d-block">ISBN</small>
                            <span class="fw-semibold">@Model?.Product?.ISBN</span>
                        </div>
                    </div>

                    <!-- Pricing -->
                    <div class="card border-0 bg-light-subtle rounded-4 mb-4">
                        <div class="card-body px-3 py-4">

                            <h6 class="fw-semibold mb-3 text-center text-uppercase text-muted">
                                Bulk Pricing
                            </h6>

                            <div class="row text-center g-3">
                                <div class="col-4">
                                    <div class="border rounded-3 py-3 h-100">
                                        <small class="text-muted d-block">1 – 50</small>
                                        <div class="fs-5 fw-bold text-success">
                                            ₹@Model?.Product?.Price
                                        </div>
                                    </div>
                                </div>

                                <div class="col-4">
                                    <div class="border rounded-3 py-3 h-100">
                                        <small class="text-muted d-block">51 – 100</small>
                                        <div class="fs-5 fw-bold text-success">
                                            ₹@Model?.Product?.Price50
                                        </div>
                                    </div>
                                </div>

                                <div class="col-4">
                                    <div class="border rounded-3 py-3 h-100">
                                        <small class="text-muted d-block">100+</small>
                                        <div class="fs-5 fw-bold text-success">
                                            ₹@Model?.Product?.Price100
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- Actions -->
                    <div>
                        <label asp-for="@Model.Count">Quantity</label>
                        <input asp-for="@Model.Count"
                               type="number"
                               min="1"
                               class="form-control w-25 -mb-4" />
                        <span asp-validation-for="@Model.Count"></span>
                    </div>

                    <div class="d-flex justify-content-center">
                        <button type="submit" class="btn btn-info">ADD TO CART</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

