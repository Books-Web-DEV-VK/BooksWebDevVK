@model PaymentRequestModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@Model.UserName - @Model.UserEmail - @Model.OrderId

@* Use the razor pay pop-up and values being passed into here , and then call the contoller for the verifying signature *@

