@*  *** Using the Razor Payment Gateway ***  *@
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<div class="card col-6 shadow-lg m-auto mt-3">
    <div class="card-header rounded-top-3 fs-1 text-center bg-primary text-white">
        Complete your Payment
    </div>
    <div class="card-body d-flex flex-column align-items-center justify-content-evenly">
        <div class="fs-2 fw-bold">Be ready with your card details</div>
        <div class="fs-2 fw-bold">
            Total amount to be paid : @Model.Amount.ToString("c")
        </div>
        <div class="w-100 p-3 d-flex justify-content-evenly">
            <button id="rzp-button" class="btn btn-primary p-3 m-3 rounded-3">
                Initiate Transaction
            </button>
            <a asp-action="Summary" class="btn btn-outline-primary p-3 m-3 rounded-3">
                Back to Summary
            </a>
        </div>
    </div>
</div>

<form id="verifyForm" asp-area="Customer" asp-controller="ShoppingCart" asp-action="VerifyPaymentStatus" method="POST">
    <input type="hidden" name="razorPayPaymentIntentId" id="razorpay-paymentId" />
    <input type="hidden" name="razorPayOrderId" id="razorpay-orderId" />
    <input type="hidden" name="razorPaySignature" id="razorpay-signature" />
    <input type="hidden" name="orderHeaderId" value="@Model.OrderId" />
</form>

<script>
    var options = {
        "key": "@Model.KeyId",
        "amount": "@(Model.Amount * 100)",
        "currency": "INR",
        "name": "Books WebApp",
        "description": "Transaction via Razor Pay Gateway to BooksWeb",
        "order_id": "@Model.OrderReceiptId",
        "handler": function (response) {
            // SUCCESS HANDLER: User paid successfully
            document.getElementById('razorpay-paymentId').value = response.razorpay_payment_id;
            document.getElementById('razorpay-orderId').value = response.razorpay_order_id;
            document.getElementById('razorpay-signature').value = response.razorpay_signature;
            document.getElementById('verifyForm').submit();
        },
        "prefill": {
            "name": "@Model.UserName",
            "email": "@Model.UserEmail"
        },
        "theme": { "color": "#3399cc" },
        "modal": {
            "ondismiss": function () {
                // FAILURE: User closed the window manually
                alert("Payment cancelled by the user.");
                window.location.href = "/Customer/Home";
            }
        }
    };

    var rzp1 = new Razorpay(options);

    // FAILURE: Card declined, timeout, or technical issue at Razorpay
    rzp1.on('payment.failed', function (response) {
        alert("Payment Failed! Reason: " + response.error.description);
        console.error("Error Code: " + response.error);
    });

    document.getElementById('rzp-button').onclick = function (e) {
        rzp1.open();
        e.preventDefault();
    }
</script>
