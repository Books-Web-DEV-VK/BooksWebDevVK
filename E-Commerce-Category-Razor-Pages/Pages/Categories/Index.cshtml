@page
@model BooksWeb_Category_Razor_Pages.Pages.Categories.IndexModel

<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">
                Category List
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-page="/Categories/CreateCategory" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i>
                Create New Category
            </a>
        </div> 
    </div>
</div>
<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Genre</th>
            <th>Display Order</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model.categoriesList.OrderBy(category=>category.DisplayOrder))
        {
            <tr>
                <td>@category.Name</td>
                <td>@category.DisplayOrder</td>
                <td>
                    <a asp-page="/Categories/EditCategory" asp-route-id="@category.Id" asp-route-actionType="edit" class="btn btn-info mx-2 rounded-2">
                        <i class="bi bi-pencil-square"></i>
                        Edit Category
                    </a>
                    <a asp-page="/Categories/DeleteConfirmation" asp-route-id="@category.Id" asp-route-actionType="delete" class="btn btn-danger mx-2 rounded-2">
                        <i class="bi bi-trash-fill"></i>
                        Delete Category
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts{
    <partial name="_ToastrConfig" />
}